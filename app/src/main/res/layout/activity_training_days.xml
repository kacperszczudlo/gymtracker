<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#212121">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Wybierz dzień treningowy"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Poniedziałek -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day1TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Poniedziałek"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day1Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Wtorek -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day2TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Wtorek"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day2Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Środa -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day3TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Środa"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day3Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Czwartek -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day4TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Czwartek"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day4Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Piątek -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day5TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Piątek"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day5Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Sobota -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day6TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Sobota"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day6Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

    <!-- Niedziela -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        <TextView
            android:id="@+id/day7TextView"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Niedziela"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
        <Button
            android:id="@+id/day7Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wybierz"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>